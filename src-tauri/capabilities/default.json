{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "opener:allow-open-url",
    "opener:allow-default-urls"
  ]
}
