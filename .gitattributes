# Normalize line endings: store text as LF in the repo and check it out as LF
# on every platform. Prevents the CRLF churn that appears when files are edited
# or saved on Windows while the project is built/run under WSL.
* text=auto eol=lf

# Shell and script files must stay LF (CRLF breaks bash shebangs / WSL).
*.sh   text eol=lf
*.mjs  text eol=lf
*.ps1  text eol=lf

# Binary assets — never apply line-ending conversion.
*.png  binary
*.ico  binary
*.icns binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
